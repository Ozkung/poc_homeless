generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CASE_MANAGER
  CARE_GIVER
  SUPER_ADMIN
  MEDICAL_VOLUNTEER
  DOCTOR
  GUEST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientStatus {
  CRITICAL
  PENDING
  STABLE
  MISSING
}

enum EventPriority {
  NORMAL
  URGENT
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  NOT_FOUND
}

enum ActivityType {
  CHECK_IN
  NOTE
  FORM_SUBMIT
  ASSIGN
  STATUS_CHANGE
  LOGIN
  LOGOUT
  SOS
  DIAGNOSIS
  PRESCRIPTION
  DISPENSE
}

enum InventoryCategory {
  DRUG
  SUPPLY
}

enum TransactionType {
  IN_PURCHASE
  IN_DONATION
  OUT_PRESCRIPTION
  OUT_SUPPLY
  ADJ_APPROVED
  OUT_EXPIRED
}

enum AdjStatus {
  PENDING
  APPROVED
  REJECTED
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  patients     Patient[]
  formTemplates FormTemplate[]
  events       Event[]
  inventoryItems  InventoryItem[]
  zones           Zone[]
  doctorSchedules DoctorSchedule[]
}

model Zone {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  color          String?
  createdAt      DateTime     @default(now())
  patients         Patient[]
  doctorSchedules  DoctorSchedule[]
  guestUsers       User[]           @relation("GuestZone")
  caseManagers     User[]           @relation("CMZone")
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  passwordHash   String
  role           UserRole
  displayName    String
  lineUserId     String?      @unique
  phone          String?
  gender         Gender?
  avatarUrl      String?
  zoneId          String?
  zone            Zone?   @relation("CMZone", fields: [zoneId], references: [id])
  preferredZoneId String?
  preferredZone   Zone?   @relation("GuestZone", fields: [preferredZoneId], references: [id])
  supervisorId   String?
  supervisor     User?   @relation("Supervisor", fields: [supervisorId], references: [id])
  subordinates   User[]  @relation("Supervisor")
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedTasks     EventTask[]  @relation("AssignedTasks")
  createdEvents     Event[]      @relation("CreatedEvents")
  managedPatients   Patient[]    @relation("ManagedPatients")
  submissions       Submission[]
  activities        Activity[]
  formTemplates     FormTemplate[]

  stockTransactions    StockTransaction[] @relation("StockActor")
  adjRequestsMade      AdjRequest[]       @relation("AdjRequester")
  adjRequestsReviewed  AdjRequest[]       @relation("AdjReviewer")
  lotsReceived         InventoryLot[]     @relation("LotReceiver")
  lotsExpired          InventoryLot[]     @relation("LotExpirer")

  diagnoses            Diagnosis[]        @relation("DoctorDiagnoses")
  prescriptions        Prescription[]     @relation("DoctorPrescriptions")
  doctorSchedules      DoctorSchedule[]   @relation("DoctorSchedules")
}

model Patient {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  caseManagerId  String?
  caseManager    User?         @relation("ManagedPatients", fields: [caseManagerId], references: [id])
  // AES-256-GCM: "iv:authTag:ciphertext" hex string
  nameEnc        String
  hn             String        @unique
  age            Int?
  gender         Gender?
  status         PatientStatus @default(PENDING)
  conditions     String[]
  locationText   String?
  phone          String?
  birthDate      DateTime?
  nationalIdEnc  String?
  zoneId  String?
  zone    Zone?   @relation(fields: [zoneId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  submissions Submission[]
  activities  Activity[]
  eventTasks  EventTask[]
  carePlanItems       CarePlanItem[]
  carePlanAssessments CarePlanAssessment[]
  alerts              Alert[]
  diagnoses           Diagnosis[]
  prescriptions       Prescription[]
}

model FormTemplate {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])
  title          String
  description    String?
  // JSON: FormField[]
  fields         Json
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  eventTasks   EventTask[]
  submissions  Submission[]
}

model Event {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User          @relation("CreatedEvents", fields: [createdById], references: [id])
  title          String
  startDate      DateTime
  endDate        DateTime
  priority       EventPriority @default(NORMAL)
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tasks      EventTask[]
  activities Activity[]
}

model EventTask {
  id               String      @id @default(uuid())
  eventId          String
  event            Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  patientId        String
  patient          Patient     @relation(fields: [patientId], references: [id])
  assigneeId       String
  assignee         User        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  formTemplateId   String?
  formTemplate     FormTemplate? @relation(fields: [formTemplateId], references: [id])
  status           TaskStatus  @default(PENDING)
  liffToken        String?
  tokenExp         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  submissions Submission[]
  activities  Activity[]
}

model Submission {
  id             String       @id @default(uuid())
  taskId         String
  task           EventTask    @relation(fields: [taskId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  formTemplateId String
  formTemplate   FormTemplate @relation(fields: [formTemplateId], references: [id])
  submittedById  String
  submittedBy    User         @relation(fields: [submittedById], references: [id])
  // [{fieldId, value}] — PII values individually AES-256-GCM encrypted
  answers        Json
  submittedAt    DateTime     @default(now())
}

model Activity {
  id         String       @id @default(uuid())
  actorId    String
  actor      User         @relation(fields: [actorId], references: [id])
  patientId  String?
  patient    Patient?     @relation(fields: [patientId], references: [id])
  eventId    String?
  event      Event?       @relation(fields: [eventId], references: [id])
  taskId     String?
  task       EventTask?   @relation(fields: [taskId], references: [id])
  type       ActivityType
  payload    Json?
  createdAt  DateTime     @default(now())
}

enum AlertType {
  OVERDUE
  MISSING
  SOS
}

model Alert {
  id          String    @id @default(uuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type        AlertType
  daysMissed  Int?
  lat         Float?
  lng         Float?
  sentAt      DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
}

model CarePlanItem {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title        String
  frequency    String
  priority     String   @default("MED")
  assigneeName String?
  isDone       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CarePlanAssessment {
  id                       String   @id @default(uuid())
  patientId                String
  patient                  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  assessmentDate           DateTime?
  locationFound            String?
  careSetting              String?
  referralSource           String?
  status                   String?
  helpGoal                 String?
  homelessType             String?
  notes                    String?
  healthcareRight          String?
  primaryCareUnit          String?
  referralUnit             String?

  ncdConditions            String[]
  infectiousConditions     String[]
  mentalConditions         String[]
  substanceConditions      String[]
  disabilityConditions     String[]
  otherConditionCategories String[]
  conditionNote            String?
  mentalConditionNote      String?

  medicalGoals             String[]
  medicalGoalOther         String?
  socialGoals              String[]
  socialGoalOther          String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Diagnosis {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      User     @relation("DoctorDiagnoses", fields: [doctorId], references: [id])
  title          String
  description    String
  icd10          String?
  severity       String?
  chiefComplaint String?
  presentIllness String?
  vitalSigns     Json?
  physicalExam   String?
  treatmentPlan  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Prescription {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      User     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  medications Json
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DoctorSchedule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  doctorId       String
  doctor         User         @relation("DoctorSchedules", fields: [doctorId], references: [id])
  zoneId         String?
  zone           Zone?        @relation(fields: [zoneId], references: [id])
  date           DateTime
  startTime      String
  endTime        String
  location       String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model InventoryItem {
  id                String            @id @default(uuid())
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id])
  name              String
  unit              String
  category          InventoryCategory
  currentStock      Int               @default(0)
  lowStockThreshold Int               @default(10)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  transactions StockTransaction[]
  adjRequests  AdjRequest[]
  lots         InventoryLot[]
}

model StockTransaction {
  id           String          @id @default(uuid())
  itemId       String
  item         InventoryItem   @relation(fields: [itemId], references: [id])
  type         TransactionType
  quantity     Int
  balanceAfter Int
  patientId    String?
  eventId      String?
  actorId      String
  actor        User            @relation("StockActor", fields: [actorId], references: [id])
  donorName    String?
  receiptNo    String?
  unitCost     Float?
  reason       String?
  lotId        String?
  lot          InventoryLot? @relation(fields: [lotId], references: [id])
  createdAt    DateTime        @default(now())
}

model AdjRequest {
  id              String        @id @default(uuid())
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id])
  requestedById   String
  requester       User          @relation("AdjRequester", fields: [requestedById], references: [id])
  quantity        Int
  reason          String
  status          AdjStatus     @default(PENDING)
  reviewedById    String?
  reviewer        User?         @relation("AdjReviewer", fields: [reviewedById], references: [id])
  reviewNote      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model InventoryLot {
  id          String        @id @default(uuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Int
  remaining   Int
  expiryDate  DateTime
  receivedAt  DateTime      @default(now())
  receiptNo   String?
  donorName   String?
  unitCost    Float?
  actorId     String
  actor       User          @relation("LotReceiver", fields: [actorId], references: [id])
  isExpired   Boolean       @default(false)
  expiredAt   DateTime?
  expiredById String?
  expiredBy   User?         @relation("LotExpirer", fields: [expiredById], references: [id])

  transactions StockTransaction[]
}
