# Database
DB_USER=homemed
DB_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change_me_256bit_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for PII (generate: openssl rand -hex 32)
ENCRYPTION_KEY=change_me_64char_hex

# NextAuth
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=change_me_nextauth_secret

# Line OA
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LIFF_ID=your_liff_id

# App URLs
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# LIFF token TTL (seconds)
LIFF_TOKEN_TTL_SECONDS=14400
